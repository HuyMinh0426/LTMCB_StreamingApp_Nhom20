<Page x:Class="ClientApp.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#141414">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- BÊN TRÁI: Banner -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E50914" Offset="0"/>
                    <GradientStop Color="#8B0000" Offset="0.5"/>
                    <GradientStop Color="#1A1A1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🎬" FontSize="80" HorizontalAlignment="Center"/>
                <TextBlock Text="MINHFLIX" Foreground="White"
                           FontSize="42" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,10"/>
                <TextBlock Text="Tạo tài khoản miễn phí"
                           Foreground="#EEEEEE" FontSize="16"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- BÊN PHẢI: Form đăng ký -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="40">
            <TextBlock Text="Đăng ký" Foreground="White"
                       FontSize="30" FontWeight="Bold" Margin="0,0,0,25"/>

            <TextBlock Text="Tài khoản" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <Border Background="#333333" CornerRadius="5" Margin="0,0,0,15">
                <TextBox x:Name="txtUsername"
                         Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="12,10" FontSize="14"/>
            </Border>

            <TextBlock Text="Mật khẩu" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <Border Background="#333333" CornerRadius="5" Margin="0,0,0,15">
                <PasswordBox x:Name="txtPassword"
                             Background="Transparent" Foreground="White"
                             BorderThickness="0" Padding="12,10" FontSize="14"/>
            </Border>

            <TextBlock Text="Nhập lại mật khẩu" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <Border Background="#333333" CornerRadius="5" Margin="0,0,0,20">
                <PasswordBox x:Name="txtConfirmPassword"
                             Background="Transparent" Foreground="White"
                             BorderThickness="0" Padding="12,10" FontSize="14"
                             KeyDown="txtConfirmPassword_KeyDown"/>
            </Border>

            <Button x:Name="btnRegister" Content="ĐĂNG KÝ"
                    Height="48" Background="#E50914" Foreground="White"
                    BorderThickness="0" FontSize="16" FontWeight="Bold"
                    Cursor="Hand" Click="btnRegister_Click"/>

            <TextBlock x:Name="txtMessage" Foreground="#FF6B6B"
                       Margin="0,15,0,0" TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <TextBlock Text="Đã có tài khoản? " Foreground="#AAAAAA"/>
                <TextBlock Text="Đăng nhập" Foreground="#E50914"
                           FontWeight="Bold" Cursor="Hand"
                           MouseLeftButtonUp="GoLogin_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>