<Window x:Class="ClientApp.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="MINHFLIX" Height="650" Width="1000"
        MinHeight="500" MinWidth="820"
        WindowStartupLocation="CenterScreen" Background="#141414">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Style cho nút trên thanh tiêu đề (chỉ là trang trí, không cần hiểu sâu) -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E50914"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Thanh tiêu đề tự vẽ -->
        <Grid DockPanel.Dock="Top" Height="36" Background="#0A0A0A">
            <TextBlock Text="MINHFLIX" Foreground="#E50914" FontWeight="Bold"
                       FontSize="14" VerticalAlignment="Center" Margin="14,0,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="—"  Style="{StaticResource CaptionButton}" Click="btnMin_Click"/>
                <Button Content="☐" Style="{StaticResource CaptionButton}" Click="btnMax_Click"/>
                <Button Content="✕"  Style="{StaticResource CloseButton}"  Click="btnClose_Click"/>
            </StackPanel>
        </Grid>

        <!-- Khung điều hướng: nơi các Page được tráo qua lại -->
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"
               Background="#141414" Navigated="MainFrame_Navigated"/>
    </DockPanel>
</Window>