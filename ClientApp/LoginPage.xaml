<Page x:Class="ClientApp.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#141414">
    <Grid>
        <Grid x:Name="contentRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- BÊN TRÁI: Banner -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E50914" Offset="0"/>
                    <GradientStop Color="#8B0000" Offset="0.5"/>
                    <GradientStop Color="#1A1A1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🎬" FontSize="80" HorizontalAlignment="Center"/>
                <TextBlock Text="MINHFLIX" Foreground="White"
                           FontSize="42" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,10"/>
                <TextBlock Text="Xem phim không giới hạn"
                           Foreground="#EEEEEE" FontSize="16"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- BÊN PHẢI: Form đăng nhập -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="40">
            <TextBlock Text="Đăng nhập" Foreground="White"
                       FontSize="30" FontWeight="Bold" Margin="0,0,0,25"/>

            

            <TextBlock Text="Tài khoản" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <Border Background="#333333" CornerRadius="5" Margin="0,0,0,15">
                <TextBox x:Name="txtUsername"
                         Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="12,10" FontSize="14"/>
            </Border>

            <TextBlock Text="Mật khẩu" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <Border Background="#333333" CornerRadius="5" Margin="0,0,0,20">
                    <PasswordBox x:Name="txtPassword"
                             Background="Transparent" Foreground="White"
                             BorderThickness="0" Padding="12,10" FontSize="14"
                             KeyDown="txtPassword_KeyDown"/>
                </Border>

            <Button x:Name="btnLogin" Content="ĐĂNG NHẬP"
                    Height="48" Background="#E50914" Foreground="White"
                    BorderThickness="0" FontSize="16" FontWeight="Bold"
                    Cursor="Hand" Click="btnLogin_Click"/>

            <TextBlock x:Name="txtMessage" Foreground="#FF6B6B"
                       Margin="0,15,0,0" TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <TextBlock Text="Chưa có tài khoản? " Foreground="#AAAAAA"/>
                <TextBlock Text="Đăng ký ngay" Foreground="#E50914"
                           FontWeight="Bold" Cursor="Hand"
                           MouseLeftButtonUp="GoRegister_Click"/>
            </StackPanel>
            </StackPanel>
        </Grid>

        <!-- LỚP PHỦ SPINNER -->
        <Grid x:Name="loadingOverlay" Visibility="Collapsed"
              Background="#CC000000" Panel.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Vòng xoay -->
                <Canvas Width="50" Height="50" HorizontalAlignment="Center">
                    <Ellipse Width="50" Height="50"
                             Stroke="#444444" StrokeThickness="5"/>
                    <Ellipse Width="50" Height="50"
                             Stroke="#E50914" StrokeThickness="5"
                             StrokeDashArray="3 1.2"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="spinnerRotate" Angle="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Canvas>
                <TextBlock Text="Đang đăng nhập..." Foreground="White"
                           FontSize="14" Margin="0,15,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Grid.Triggers>
                <EventTrigger RoutedEvent="Grid.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetName="spinnerRotate"
                                Storyboard.TargetProperty="Angle"
                                From="0" To="360" Duration="0:0:1"
                                RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
    </Grid>
</Page>