<Page x:Class="ClientApp.MovieDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
      Background="#141414" Focusable="True"
      Loaded="Page_Loaded" KeyDown="Page_KeyDown">

    <Page.Resources>
        <Style x:Key="VideoBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E50914"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MediaSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="#555555"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Height="4">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="#E50914"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Height="4">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="13" Height="13">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="13" Height="13" Fill="#E50914"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Thanh trên -->
        <Border x:Name="topBar" Grid.Row="0" Background="#000000" Padding="15,8">
            <Button x:Name="btnBack" Content="←  Quay lại"
                    HorizontalAlignment="Left"
                    Background="Transparent" Foreground="White"
                    BorderThickness="0" FontSize="15" Cursor="Hand"
                    Click="btnBack_Click"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="infoColumn" Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- BÊN TRÁI -->
            <Border x:Name="infoPanel" Grid.Column="0" Background="#1A1A1A" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border CornerRadius="8" ClipToBounds="True" Height="380" Margin="0,0,0,15">
                        <Image x:Name="imgPoster" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock x:Name="txtTitle" Foreground="White"
                               FontSize="22" FontWeight="Bold"
                               TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <Border Background="#E50914" CornerRadius="4"
                            Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,12">
                        <TextBlock x:Name="txtCategory" Foreground="White" FontSize="12"/>
                    </Border>
                    <TextBlock x:Name="txtDescription" Foreground="#CCCCCC"
                               FontSize="14" TextWrapping="Wrap"
                               LineHeight="22" Margin="0,0,0,20"/>

                        <!-- Stats xem phim -->
                        <Border Background="#1f1f1f" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="ĐANG XEM" Foreground="#666" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtViewers" Foreground="#4CAF50"
                                           FontSize="16" FontWeight="Bold" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Width="1" Background="#333" Margin="0,0,20,0"/>
                                <StackPanel>
                                    <TextBlock Text="LƯỢT XEM" Foreground="#666" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtTotalViews" Foreground="#E50914"
                                           FontSize="16" FontWeight="Bold" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Button x:Name="btnPlay" Content="▶  XEM PHIM"
                            Height="48" FontSize="16" FontWeight="Bold"
                            Background="#E50914" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="btnPlay_Click"/>
                    <TextBlock x:Name="txtStatus" Foreground="#888888"
                               FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap"/>

                    <Grid x:Name="loadingArea" Visibility="Collapsed" Margin="0,10,0,0">
                        <ProgressBar x:Name="pbLoading" Height="8" Minimum="0" Maximum="100"
                                     Background="#333333" Foreground="#E50914"
                                     BorderThickness="0"/>
                        <TextBlock x:Name="txtPercent" Text="0%" Foreground="White"
                                   FontSize="11" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Bình luận -->
                    <TextBlock Text="Bình luận" Foreground="White" FontSize="16"
                               FontWeight="Bold" Margin="0,20,0,8"/>

                    <Border Background="#111111" CornerRadius="6" Height="150" Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="icComments">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8" Padding="6" CornerRadius="4"
                                                    Background="#1a1a1a">
                                                <StackPanel>
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Username}" Foreground="#E50914"
                                                                       FontWeight="Bold" FontSize="12"/>
                                                            <TextBlock Text="{Binding Time}" Foreground="#666666"
                                                                       FontSize="10" Margin="8,0,0,0"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Button Content="⚑" HorizontalAlignment="Right"
                                                                Background="Transparent" Foreground="#555"
                                                                BorderThickness="0" FontSize="12"
                                                                Cursor="Hand" Padding="4,0"
                                                                Tag="{Binding}"
                                                                Click="btnReport_Click"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding Content}" Foreground="#CCCCCC"
                                                               FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                    </Border>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#222222" CornerRadius="4">
                            <TextBox x:Name="txtComment" Background="Transparent"
                                     Foreground="White" BorderThickness="0"
                                     Padding="8,6" FontSize="12"
                                     KeyDown="txtComment_KeyDown"/>
                        </Border>
                        <Button Grid.Column="1" Content="Gửi" Margin="6,0,0,0"
                                Width="50" Background="#E50914" Foreground="White"
                                BorderThickness="0" FontSize="12" Cursor="Hand"
                                Click="btnSendComment_Click"/>
                    </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- BÊN PHẢI: Video + Chat -->
            <Grid Grid.Column="1" Background="Black">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="chatColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- Video + Controls -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="Black" MouseLeftButtonDown="VideoArea_MouseDown">
                        <vlc:VideoView x:Name="videoView"/>
                        <TextBlock x:Name="txtVideoPlaceholder"
                                   Text="🎬 Bấm XEM PHIM để bắt đầu"
                                   Foreground="#555555" FontSize="20" IsHitTestVisible="False"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                <!-- Thanh điều khiển -->
                <Border x:Name="controlBar" Grid.Row="1"
                        Background="#000000" Padding="14,8" Visibility="Collapsed">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtCurrent" Grid.Column="0" Text="0:00"
                                       Foreground="White" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Slider x:Name="seekBar" Grid.Column="1" Minimum="0" Maximum="1000"
                                    VerticalAlignment="Center" IsMoveToPointEnabled="True"
                                    Style="{StaticResource MediaSlider}"
                                    Thumb.DragStarted="seekBar_DragStarted"
                                    Thumb.DragCompleted="seekBar_DragCompleted"
                                    ValueChanged="seekBar_ValueChanged"/>
                            <TextBlock x:Name="txtTotal" Grid.Column="2" Text="0:00"
                                       Foreground="White" FontSize="12"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="btnBack10" Content="« 10s"
                                        Style="{StaticResource VideoBtn}" Click="btnBack10_Click"/>
                                <Button x:Name="btnPlayPause" Content="❚❚" FontSize="16"
                                        Style="{StaticResource VideoBtn}" Click="btnPlayPause_Click"/>
                                <Button x:Name="btnFwd10" Content="10s »"
                                        Style="{StaticResource VideoBtn}" Click="btnFwd10_Click"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button x:Name="btnMute" Content="🔊"
                                        Style="{StaticResource VideoBtn}" Click="btnMute_Click"/>
                                <Slider x:Name="volBar" Width="90" Minimum="0" Maximum="100"
                                        Value="100" VerticalAlignment="Center"
                                        Style="{StaticResource MediaSlider}"
                                        ValueChanged="volBar_ValueChanged"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="btnChat" Content="💬"
                                        Style="{StaticResource VideoBtn}" Click="btnChat_Click"/>
                                <Button x:Name="btnFull" Content="⛶"
                                        Style="{StaticResource VideoBtn}" Click="btnFull_Click"/>
                            </StackPanel>
                        </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Chat Panel (ẩn mặc định, bấm 💬 mới hiện) -->
                <Border x:Name="chatPanel" Grid.Column="1" Background="#1A1A1A"
                        Visibility="Collapsed" Width="280">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="💬 Chat trực tiếp" Foreground="White"
                                       FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="" Foreground="#666666" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="#111111" CornerRadius="6" Padding="8">
                            <ScrollViewer x:Name="chatScroll" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="icChat">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,6">
                                                <TextBlock Foreground="#E50914" FontSize="11" FontWeight="Bold"
                                                           Text="{Binding Username}"/>
                                                <TextBlock Foreground="#CCCCCC" FontSize="12"
                                                           TextWrapping="Wrap" Text="{Binding Content}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#222222" CornerRadius="4">
                                <TextBox x:Name="txtChatInput" Background="Transparent"
                                         Foreground="White" BorderThickness="0"
                                         Padding="8,6" FontSize="12"
                                         KeyDown="txtChatInput_KeyDown"/>
                            </Border>
                            <Button Grid.Column="1" Content="Gửi" Margin="6,0,0,0"
                                    Width="45" Background="#E50914" Foreground="White"
                                    BorderThickness="0" FontSize="12" Cursor="Hand"
                                    Click="btnSendChat_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>