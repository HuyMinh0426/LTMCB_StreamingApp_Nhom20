<Page x:Class="ClientApp.MovieDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
      Background="#0A0A0A" Focusable="True"
      Loaded="Page_Loaded" KeyDown="Page_KeyDown">

    <Page.Resources>
        <Style x:Key="VideoBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E50914"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MediaSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="#555555"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Height="4">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="#E50914"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Height="4">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14" Fill="#E50914"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Thanh trên -->
        <Border x:Name="topBar" Grid.Row="0" Background="#000000" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnBack" Grid.Column="0"
                        Content="←  Quay lại"
                        Background="Transparent" Foreground="White"
                        BorderThickness="0" FontSize="15" Cursor="Hand"
                        Click="btnBack_Click"/>

                <TextBlock x:Name="txtTitle" Grid.Column="1"
                           Foreground="White" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock x:Name="txtViewers" Grid.Column="2"
                           Foreground="#4CAF50" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </Grid>
        </Border>

        <!-- Khu vực xem phim + chat -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="chatColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Video Full Width -->
            <Grid Grid.Column="0" Background="Black">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Video area -->
                <Grid Grid.Row="0" Background="Black" MouseLeftButtonDown="VideoArea_MouseDown">
                    <vlc:VideoView x:Name="videoView"/>

                    <!-- Placeholder khi chưa phát -->
                    <StackPanel x:Name="videoPlaceholder"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🎬" FontSize="60"
                                   Foreground="#555555" HorizontalAlignment="Center"/>
                        <TextBlock Text="Đang tải phim từ server..."
                                   Foreground="#888888" FontSize="16"
                                   HorizontalAlignment="Center" Margin="0,10,0,20"/>

                        <!-- Loading progress -->
                        <Grid x:Name="loadingArea" Width="300" Visibility="Collapsed">
                            <ProgressBar x:Name="pbLoading" Height="10" Minimum="0" Maximum="100"
                                         Background="#333333" Foreground="#E50914"
                                         BorderThickness="0"/>
                            <TextBlock x:Name="txtPercent" Text="0%" Foreground="White"
                                       FontSize="12" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock x:Name="txtStatus" Foreground="#666666"
                                   FontSize="12" Margin="0,12,0,0"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <!-- Control bar dưới video -->
                <Border x:Name="controlBar" Grid.Row="1"
                        Background="#0A0A0A" Padding="20,12" Visibility="Collapsed">
                    <StackPanel>
                        <!-- Thanh tua -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtCurrent" Grid.Column="0" Text="0:00"
                                       Foreground="White" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider x:Name="seekBar" Grid.Column="1" Minimum="0" Maximum="1000"
                                    VerticalAlignment="Center" IsMoveToPointEnabled="True"
                                    Style="{StaticResource MediaSlider}"
                                    Thumb.DragStarted="seekBar_DragStarted"
                                    Thumb.DragCompleted="seekBar_DragCompleted"
                                    ValueChanged="seekBar_ValueChanged"/>
                            <TextBlock x:Name="txtTotal" Grid.Column="2" Text="0:00"
                                       Foreground="White" FontSize="13"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>

                        <!-- Nút điều khiển -->
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="btnBack10" Content="« 10s"
                                        Style="{StaticResource VideoBtn}" Click="btnBack10_Click"/>
                                <Button x:Name="btnPlayPause" Content="❚❚" FontSize="18"
                                        Style="{StaticResource VideoBtn}" Click="btnPlayPause_Click"/>
                                <Button x:Name="btnFwd10" Content="10s »"
                                        Style="{StaticResource VideoBtn}" Click="btnFwd10_Click"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button x:Name="btnMute" Content="🔊"
                                        Style="{StaticResource VideoBtn}" Click="btnMute_Click"/>
                                <Slider x:Name="volBar" Width="100" Minimum="0" Maximum="100"
                                        Value="100" VerticalAlignment="Center"
                                        Style="{StaticResource MediaSlider}"
                                        ValueChanged="volBar_ValueChanged"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="btnChat" Content="💬 Chat"
                                        Style="{StaticResource VideoBtn}" Click="btnChat_Click"/>
                                <Button x:Name="btnFull" Content="⛶"
                                        Style="{StaticResource VideoBtn}" Click="btnFull_Click"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Chat Panel bên phải (toggle) -->
            <Border x:Name="chatPanel" Grid.Column="1" Background="#141414"
                    Visibility="Collapsed" Width="320">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0A0A0A" CornerRadius="6"
                            Padding="12,8" Margin="0,0,0,10">
                        <TextBlock Text="💬 Chat trực tiếp" Foreground="White"
                                   FontSize="15" FontWeight="Bold"/>
                    </Border>

                    <Border Grid.Row="1" Background="#0A0A0A" CornerRadius="6" Padding="10">
                        <ScrollViewer x:Name="chatScroll" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icChat">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Foreground="#E50914" FontSize="12" FontWeight="Bold"
                                                       Text="{Binding Username}"/>
                                            <TextBlock Foreground="#DDDDDD" FontSize="13"
                                                       TextWrapping="Wrap" Text="{Binding Content}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#222222" CornerRadius="4">
                            <TextBox x:Name="txtChatInput" Background="Transparent"
                                     Foreground="White" BorderThickness="0"
                                     Padding="10,8" FontSize="13"
                                     KeyDown="txtChatInput_KeyDown"/>
                        </Border>
                        <Button Grid.Column="1" Content="Gửi" Margin="6,0,0,0"
                                Width="55" Background="#E50914" Foreground="White"
                                BorderThickness="0" FontSize="13" Cursor="Hand"
                                Click="btnSendChat_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>