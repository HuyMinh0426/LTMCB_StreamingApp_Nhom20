<Page x:Class="ClientApp.MoviesPage"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          Background="#141414">
    <Page.Resources>
        <Style x:Key="PosterCard" TargetType="Border">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="#E50914"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderThickness" Value="3"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.08" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.08" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <StackPanel>
                            <ContentPresenter HorizontalAlignment="Center"/>
                            <Border x:Name="underline" Height="2" Margin="0,4,0,0"
                                        Background="#E50914" Visibility="Collapsed"/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E50914"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0A0A0A" BorderBrush="#222222" BorderThickness="0,0,0,1">
            <Grid Margin="25,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="NT106.Q22.ANTT"
                               Foreground="#E50914" FontSize="22" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,50,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Tất cả" Style="{StaticResource NavItem}" Tag="All" Click="Category_Click"/>
                    <Button Content="Anime" Style="{StaticResource NavItem}" Tag="Anime" Click="Category_Click"/>
                    <Button Content="Phim Việt" Style="{StaticResource NavItem}" Tag="Phim Việt" Click="Category_Click"/>
                    <Button Content="Phim Hàn" Style="{StaticResource NavItem}" Tag="Phim Hàn" Click="Category_Click"/>
                    <Button Content="Chiếu Rạp" Style="{StaticResource NavItem}" Tag="Chiếu Rạp" Click="Category_Click"/>
                </StackPanel>

                <Border Grid.Column="2" Background="#1F1F1F" CornerRadius="20"
                            BorderBrush="#333333" BorderThickness="1"
                            Width="260" Height="36" HorizontalAlignment="Right" Margin="0,0,20,0">
                    <Grid>
                        <TextBlock Text="🔍  Tìm phim..." Foreground="#888888"
                                       Margin="14,0" VerticalAlignment="Center"
                                       x:Name="txtPlaceholder" IsHitTestVisible="False"/>
                        <TextBox x:Name="txtSearch" Background="Transparent"
                                     Foreground="White" BorderThickness="0"
                                     Margin="14,0" VerticalAlignment="Center"
                                     TextChanged="txtSearch_TextChanged"
                                     GotFocus="txtSearch_GotFocus" LostFocus="txtSearch_LostFocus"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="userButton" Background="Transparent" Cursor="Hand"
                                MouseLeftButtonUp="UserButton_Click" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#E50914" CornerRadius="12" Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="12" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="txtUser" Text="user" Foreground="White"
                                           FontSize="14" VerticalAlignment="Center" Margin="8,0,4,0"/>
                            <TextBlock Text="▾" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Popup x:Name="userMenu" PlacementTarget="{Binding ElementName=userButton}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                               HorizontalOffset="-80" VerticalOffset="8">
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="6"
                                    BorderBrush="#333333" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.6"/>
                            </Border.Effect>
                            <StackPanel Width="200">
                                <Button Content="👤   Thông tin tài khoản" Style="{StaticResource MenuItem}" Click="MenuInfo_Click"/>
                                <Button Content="📦   Hộp phim" Style="{StaticResource MenuItem}" Click="MenuFavorites_Click"/>
                                <Button Content="🕘   Lịch sử" Style="{StaticResource MenuItem}" Click="MenuHistory_Click"/>
                                <Border Height="1" Background="#333333" Margin="6,4"/>
                                <Button Content="⏻   Thoát" Style="{StaticResource MenuItem}" Click="MenuLogout_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Banner cảnh cáo tài khoản -->
        <Border x:Name="warningBanner" Grid.Row="1" Background="#b71c1c"
                Padding="15,10" Visibility="Collapsed"
                VerticalAlignment="Top" Panel.ZIndex="99">
            <TextBlock Text="⚠ Tài khoản của bạn thuộc diện cảnh cáo vì vi phạm tiêu chuẩn cộng đồng. Vui lòng tuân thủ nội quy."
                       Foreground="White" FontSize="13" TextWrapping="Wrap"/>
        </Border>

        <!-- DÃY NGANG -->
        <ScrollViewer x:Name="rowsView" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="20,15" CanContentScroll="False" PanningMode="VerticalOnly">
            <ItemsControl x:Name="icRows">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,25">
                            <Grid Margin="4,0,0,10">
                                <TextBlock Text="{Binding CategoryName}" Foreground="White"
                                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Left"/>
                                <Button Content="Tất cả ›" Tag="{Binding CategoryName}"
                                            Click="ViewAllCategory_Click"
                                            HorizontalAlignment="Right" Margin="0,0,15,0"
                                            Background="Transparent" Foreground="#AAAAAA"
                                            BorderThickness="0" FontSize="13" Cursor="Hand"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Content="‹" Click="ScrollLeft_Click"
                                            Width="32" Height="250" FontSize="22" Cursor="Hand"
                                            Background="#88000000" Foreground="White" BorderThickness="0"/>

                                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled" CanContentScroll="False"
                                                  PreviewMouseWheel="RowScroll_PreviewMouseWheel">
                                    <ItemsControl ItemsSource="{Binding Movies}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="160" Height="250" Margin="6"
                                                            CornerRadius="6" Background="#222222"
                                                            Style="{StaticResource PosterCard}"
                                                            MouseLeftButtonUp="Movie_Click" Cursor="Hand">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                                                    </Border.Effect>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Border Grid.Row="0" CornerRadius="6,6,0,0" ClipToBounds="True">
                                                            <Image Source="{Binding PosterImage}" Stretch="UniformToFill"/>
                                                        </Border>
                                                        <TextBlock Grid.Row="1" Text="{Binding Title}"
                                                                       Foreground="White" FontSize="12"
                                                                       FontWeight="SemiBold" Margin="8,6"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       TextAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Button Grid.Column="2" Content="›" Click="ScrollRight_Click"
                                            Width="32" Height="250" FontSize="22" Cursor="Hand"
                                            Background="#88000000" Foreground="White" BorderThickness="0"/>
                            </Grid>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- LƯỚI -->
        <ScrollViewer x:Name="gridView" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="20,15" CanContentScroll="False" PanningMode="VerticalOnly"
                          Visibility="Collapsed">
            <ItemsControl x:Name="icMovies">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="180" Height="290" Margin="8"
                                    CornerRadius="6" Background="#222222"
                                    Style="{StaticResource PosterCard}"
                                    MouseLeftButtonUp="Movie_Click" Cursor="Hand">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" CornerRadius="6,6,0,0" ClipToBounds="True">
                                    <Image Source="{Binding PosterImage}" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Grid.Row="1" Text="{Binding Title}"
                                               Foreground="White" FontSize="13"
                                               FontWeight="SemiBold" Margin="8,6"
                                               TextTrimming="CharacterEllipsis"
                                               TextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>