<Page x:Class="ClientApp.MovieInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#141414" Focusable="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Thanh trên: nút quay lại -->
        <Border Grid.Row="0" Background="#000000" Padding="15,8">
            <Button x:Name="btnBack" Content="←  Quay lại danh sách phim"
                    HorizontalAlignment="Left"
                    Background="Transparent" Foreground="White"
                    BorderThickness="0" FontSize="15" Cursor="Hand"
                    Click="btnBack_Click"/>
        </Border>

        <!-- Nội dung chính -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="40,30,40,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Phần trên: Poster + Info -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Poster to bên trái -->
                    <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True"
                            Width="280" Height="420" Margin="0,0,30,0">
                        <Image x:Name="imgPoster" Stretch="UniformToFill"/>
                    </Border>

                    <!-- Info bên phải -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                        <TextBlock x:Name="txtTitle" Foreground="White"
                                   FontSize="36" FontWeight="Bold"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <Border Background="#E50914" CornerRadius="4"
                                Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,20">
                            <TextBlock x:Name="txtCategory" Foreground="White" FontSize="14"/>
                        </Border>

                        <!-- Stats -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Border Background="#1f1f1f" CornerRadius="8" Padding="16,10" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="LƯỢT XEM" Foreground="#666" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock x:Name="txtTotalViews" Foreground="#E50914"
                                               FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Mô tả -->
                        <TextBlock Text="TÓM TẮT PHIM" Foreground="#E50914"
                                   FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtDescription" Foreground="#CCCCCC"
                                   FontSize="15" TextWrapping="Wrap"
                                   LineHeight="24" Margin="0,0,0,24"/>

                        <!-- Nút xem phim -->
                        <Button x:Name="btnWatch" Content="▶  XEM PHIM"
                                Height="56" Width="220" HorizontalAlignment="Left"
                                FontSize="18" FontWeight="Bold"
                                Background="#E50914" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="btnWatch_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Đường kẻ ngăn cách -->
                <Border Grid.Row="1" Height="1" Background="#333"
                        Margin="0,40,0,30"/>

                <!-- Phần dưới: Bình luận -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="💬 BÌNH LUẬN" Foreground="White"
                               FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

                    <!-- Ô nhập bình luận -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#222222" CornerRadius="6">
                            <TextBox x:Name="txtComment" Background="Transparent"
                                     Foreground="White" BorderThickness="0"
                                     Padding="12,10" FontSize="14"
                                     KeyDown="txtComment_KeyDown"/>
                        </Border>
                        <Button Grid.Column="1" Content="Gửi" Margin="8,0,0,0"
                                Width="80" Background="#E50914" Foreground="White"
                                BorderThickness="0" FontSize="14" Cursor="Hand"
                                Click="btnSendComment_Click"/>
                    </Grid>

                    <!-- Danh sách bình luận -->
                    <ItemsControl x:Name="icComments">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10" Padding="14" CornerRadius="6"
                                        Background="#1a1a1a">
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Username}" Foreground="#E50914"
                                                           FontWeight="Bold" FontSize="14"/>
                                                <TextBlock Text="{Binding Time}" Foreground="#666666"
                                                           FontSize="11" Margin="10,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button Content="⚑ Báo cáo" HorizontalAlignment="Right"
                                                    Background="Transparent" Foreground="#888"
                                                    BorderThickness="0" FontSize="11"
                                                    Cursor="Hand" Padding="6,2"
                                                    Tag="{Binding}"
                                                    Click="btnReport_Click"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Content}" Foreground="#DDDDDD"
                                                   FontSize="13" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>